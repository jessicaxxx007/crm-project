<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yjx.dao.RoleMapper">
    <resultMap id="BaseResultMap" type="com.yjx.vo.Role">
        <id column="id" jdbcType="INTEGER" property="id"/>
        <result column="role_name" jdbcType="VARCHAR" property="roleName"/>
        <result column="role_remark" jdbcType="VARCHAR" property="roleRemark"/>
        <result column="is_valid" jdbcType="INTEGER" property="isValid"/>
        <result column="create_date" jdbcType="TIMESTAMP" property="createDate"/>
        <result column="update_date" jdbcType="TIMESTAMP" property="updateDate"/>
    </resultMap>
    <sql id="Base_Column_List">
        id, role_name, role_remark, is_valid, create_date, update_date
    </sql>

    <insert id="insertSelective" parameterType="com.yjx.vo.Role" useGeneratedKeys="true" keyProperty="id">
        insert into t_role
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="roleName != null">role_name,</if>
            <if test="roleRemark != null">role_remark,</if>
            <if test="isValid != null">is_valid,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="roleName != null">#{roleName,jdbcType=VARCHAR},</if>
            <if test="roleRemark != null">#{roleRemark,jdbcType=VARCHAR},</if>
            <if test="isValid != null">#{isValid,jdbcType=INTEGER},</if>
        </trim>
    </insert>
    <insert id="insertHasKey" parameterType="com.yjx.vo.Role" useGeneratedKeys="true" keyProperty="id">
        insert into t_role (role_name, role_remark, is_valid) values (#{roleName}, #{roleRemark}, #{isValid})
    </insert>
    <insert id="insertBatch" parameterType="java.util.List">
        insert into t_role (role_name, role_remark, is_valid) values
        <foreach collection="list" item="item" separator=",">
            (#{item.roleName}, #{item.roleRemark}, #{item.isValid})
        </foreach>
    </insert>

    <select id="selectByPrimaryKey" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from t_role where id = #{id,jdbcType=INTEGER} and is_valid = 1
    </select>
    <select id="selectByParams" parameterType="com.yjx.query.RoleQuery" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from t_role where is_valid = 1
        <if test="roleName != null and roleName != ''">
            and role_name like concat('%',#{roleName},'%')
        </if>
        order by create_date desc
    </select>

    <update id="updateByPrimaryKeySelective" parameterType="com.yjx.vo.Role">
        update t_role
        <set>
            <if test="roleName != null">role_name = #{roleName,jdbcType=VARCHAR},</if>
            <if test="roleRemark != null">role_remark = #{roleRemark,jdbcType=VARCHAR},</if>
        </set>
        where id = #{id,jdbcType=INTEGER}
    </update>
    <update id="updateBatch" parameterType="java.util.List">
        <foreach collection="list" item="item" separator=";">
            update t_role set role_name = #{item.roleName} where id = #{item.id}
        </foreach>
    </update>

    <delete id="deleteByPrimaryKey" parameterType="java.lang.Integer">
        update t_role set is_valid = 0 where id = #{id,jdbcType=INTEGER}
    </delete>
    <delete id="deleteBatch" parameterType="java.lang.Integer">
        update t_role set is_valid = 0 where id in
        <foreach collection="array" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
    </delete>

    <select id="queryAllRoles" resultType="java.util.Map">
        select id, role_name as roleName from t_role where is_valid = 1
    </select>

    <select id="queryRoleNamesByRoleIds" resultType="java.lang.String">
        select group_concat(role_name separator ', ')
        from t_role
        where is_valid = 1
        and find_in_set(id, #{roleIds})
    </select>
</mapper>
